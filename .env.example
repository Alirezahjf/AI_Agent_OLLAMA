# Copy this file to .env. Never commit real tokens or API keys.
TELEGRAM_BOT_TOKEN=replace-with-token-from-telegram-botfather
# Comma-separated Telegram numeric IDs. Leave blank only while initially discovering your ID.
ALLOWED_TELEGRAM_USER_IDS=

# Optional Bale messenger bot with the exact same agent capabilities.
# Create it with @botfather inside Bale (https://ble.ir/botfather).
BALE_BOT_TOKEN=
# Comma-separated Bale numeric IDs. Leave blank only while initially discovering your ID.
ALLOWED_BALE_USER_IDS=
# Bale Bot API endpoints; keep defaults unless Bale changes its gateway.
BALE_API_BASE_URL=https://tapi.bale.ai
BALE_FILE_BASE_URL=https://tapi.bale.ai/file

# The agent may only access this existing directory and its children.
# Use a dedicated projects folder, never / or your whole home directory.
WORKSPACE_ROOT=/home/your-user/projects
# SQLite conversations/audit are stored here; keep it private and outside edited projects.
DATA_DIR=./data

# ---- Model provider ----
# ollama | gapgpt | avalai | auto
# auto chooses AvalAI if AVALAI_API_KEY exists, then GapGPT, otherwise Ollama.
DEFAULT_PROVIDER=ollama
# Optional provider-specific override. Leave blank to use a recommended default.
DEFAULT_MODEL=

# Ollama must be running locally: ollama serve
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# OpenAI-compatible cloud endpoints. Keep API keys only in .env or a secret manager.
# The Telegram UI can also accept a session-only key; it is never stored in SQLite.
GAPGPT_BASE_URL=https://api.gapgpt.app/v1
GAPGPT_API_KEY=
AVALAI_BASE_URL=https://api.avalai.ir/v1
AVALAI_API_KEY=
# AvalAI service tier for interactive bot usage: default is recommended.
# Use flex only for slow/background work; the client falls back to default when flex fails.
AVALAI_SERVICE_TIER=default
# Retries for cloud provider transient errors (429/5xx/timeout/SSL EOF), 0..8.
PROVIDER_MAX_RETRIES=4

# ---- Workflow limits ----
COMMAND_TIMEOUT_SECONDS=120
MODEL_TIMEOUT_SECONDS=180
MAX_OUTPUT_CHARS=12000
# Bounded agent loop prevents accidental endless tool use (1..32).
MAX_AGENT_TURNS=16
# Set true only inside an isolated disposable VM/container. Hard blocks still apply.
AUTO_APPROVE_MUTATIONS=false
