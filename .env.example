# Create .env from this file. Never commit your real token.
TELEGRAM_BOT_TOKEN=replace-with-token-from-botfather
# Ollama must be running locally: ollama serve
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
# Comma-separated Telegram numeric IDs. Leave blank only while initially discovering your ID.
ALLOWED_TELEGRAM_USER_IDS=
# The agent may only access this directory and its children.
WORKSPACE_ROOT=/home/your-user/projects
# SQLite data is stored here; preferably outside a repository being edited.
DATA_DIR=./data
# Command limits
COMMAND_TIMEOUT_SECONDS=120
MAX_OUTPUT_CHARS=12000
# Set true only on an isolated machine. It removes per-action approval (hard blocks remain).
AUTO_APPROVE_MUTATIONS=false
